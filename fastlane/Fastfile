default_platform(:ios)

# ─── API Key Configuration ──────────────────────────────────────────────────
# Replace KEY_ID and ISSUER_ID below with your App Manager-role API key.
# The Developer-role key (used for xcodebuild upload) does NOT have metadata access.
# Create a new key: App Store Connect → Users and Access → Integrations → App Store Connect API
# Select role: App Manager
API_KEY_ID     = ENV["ASC_KEY_ID"]     || "6UNR62377K"        # replace if new key
API_ISSUER_ID  = ENV["ASC_ISSUER_ID"]  || "fcb22995-afe3-4c7c-8ef7-447c3b1c92be"
API_KEY_PATH   = ENV["ASC_KEY_PATH"]   || "~/.appstoreconnect/private_keys/AuthKey_#{API_KEY_ID}.p8"

platform :ios do

  # ── Push metadata (description, keywords, subtitle, etc.) to App Store Connect
  lane :metadata do
    api_key = app_store_connect_api_key(
      key_id:        API_KEY_ID,
      issuer_id:     API_ISSUER_ID,
      key_filepath:  File.expand_path(API_KEY_PATH),
      duration:      1200,
      in_house:      false
    )

    deliver(
      api_key:              api_key,
      app_identifier:       "clarkdjcr.ApPolForgeSym",
      skip_binary_upload:   true,
      skip_screenshots:     true,
      overwrite_screenshots: false,
      metadata_path:        "./fastlane/metadata",
      force:                true,   # skip HTML diff preview
      run_precheck_before_submit: false
    )
  end

  # ── Upload a pre-built IPA to App Store Connect (no metadata update)
  lane :upload do |options|
    api_key = app_store_connect_api_key(
      key_id:        API_KEY_ID,
      issuer_id:     API_ISSUER_ID,
      key_filepath:  File.expand_path(API_KEY_PATH),
      duration:      1200,
      in_house:      false
    )

    deliver(
      api_key:            api_key,
      app_identifier:     "clarkdjcr.ApPolForgeSym",
      ipa:                options[:ipa] || "~/Desktop/CampaignManager-iOS-Export/ApPolForgeSym.ipa",
      skip_metadata:      true,
      skip_screenshots:   true,
      force:              true
    )
  end

end
